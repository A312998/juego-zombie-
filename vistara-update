<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Poppins,sans-serif;
scroll-behavior:smooth;
}

body{
background:#0b1220;
color:white;
overflow-x:hidden;
}

/* Fondo animado */

body::before{
content:"";
position:fixed;
left:0;
top:0;
width:100%;
height:100%;
background:
radial-gradient(circle at 20% 20%,rgba(0,140,255,.15),transparent 35%),
radial-gradient(circle at 80% 10%,rgba(0,255,255,.12),transparent 35%),
radial-gradient(circle at 50% 80%,rgba(0,80,255,.20),transparent 40%);
animation:fondo 18s infinite alternate;
z-index:-2;
}

@keyframes fondo{

0%{
transform:scale(1);
}

100%{
transform:scale(1.2) rotate(5deg);
}

}

/* SIDEBAR */

.sidebar{

position:fixed;
left:0;
top:0;
width:250px;
height:100%;
background:rgba(18,26,44,.82);
backdrop-filter:blur(20px);
padding:25px;
overflow:auto;
box-shadow:0 0 40px rgba(0,0,0,.5);

}

.logo{

font-size:35px;
font-weight:bold;
text-align:center;
margin-bottom:30px;

}

.logo span{

color:#3da6ff;

}

.sidebar a{

display:block;
text-decoration:none;
color:white;
padding:14px;
margin:7px 0;
border-radius:10px;
transition:.30s;

}

.sidebar a:hover{

background:#2196f3;
transform:translateX(8px);

}

/* CONTENIDO */

.content{

margin-left:270px;

}

.hero{

height:100vh;
display:flex;
justify-content:center;
align-items:center;
flex-direction:column;
text-align:center;

}

.hero h1{

font-size:70px;
margin-bottom:15px;
animation:zoom 1s;

}

.hero p{

font-size:22px;
color:#d6d6d6;

}

.hero button{

margin-top:35px;
padding:18px 50px;
font-size:18px;
border:none;
border-radius:40px;
cursor:pointer;
background:#2196f3;
color:white;
transition:.4s;

}

.hero button:hover{

transform:scale(1.1);
box-shadow:0 0 25px #2196f3;

}

@keyframes zoom{

from{

opacity:0;
transform:scale(.5);

}

to{

opacity:1;
transform:scale(1);

}

}

section{

padding:90px 50px;

}

section h2{

font-size:42px;
margin-bottom:35px;

}

.cards{

display:grid;
grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
gap:25px;

}

.card{

background:rgba(255,255,255,.05);
backdrop-filter:blur(18px);
padding:25px;
border-radius:20px;
transition:.35s;
border:1px solid rgba(255,255,255,.08);

}

.card:hover{

transform:translateY(-10px) scale(1.02);
box-shadow:0 0 30px rgba(33,150,243,.4);

}

.card h3{

margin-bottom:15px;
color:#42a5f5;

}

.card ul{

padding-left:18px;

}

.card li{

margin:8px 0;

}

footer{

padding:70px;
text-align:center;
font-size:18px;
background:#111827;

}

.progress{

position:fixed;
top:0;
left:0;
height:5px;
background:#2196f3;
width:0%;
z-index:999;

}

</style>

